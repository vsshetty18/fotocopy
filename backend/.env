# ====================================================
# Server
# ====================================================
PORT=5000
NODE_ENV=production

# ====================================================
# Database (Render PostgreSQL — copy the "External Database URL"
# or "Internal Database URL" from your Render Postgres dashboard)
# ====================================================
DATABASE_URL=postgresql://username:password@host:5432/dbname

# ====================================================
# JWT Auth
# ====================================================
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ====================================================
# Cloudinary (from your Cloudinary Dashboard > Account Details)
# ====================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ====================================================
# OpenAI (Images API)
# ====================================================
OPENAI_API_KEY=sk-your_openai_key

# ====================================================
# Face Recognition Microservice (separate Render service,
# Python + Flask + InsightFace)
# ====================================================
FACE_SERVICE_URL=https://photoai-face-service.onrender.com

# ====================================================
# Frontend URL (for CORS — your exact Vercel deployment URL,
# no trailing slash)
# ====================================================
FRONTEND_URL=https://your-app.vercel.app
